@page
@model TechSupportRagBot.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Password reset";
}

<div class="auth-layout">
    <form method="post" class="auth-card">
        <p class="eyebrow">Class-Engineering Support</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "Reset password", "Сброс пароля")</h1>

        @if (Model.Sent)
        {
            <div class="notice-success">
                @TechSupportRagBot.Services.UiText.T(HttpContext, "If the account exists and has email, a reset link has been sent.", "Если учетная запись существует и у нее указана почта, ссылка для смены пароля отправлена.")
            </div>
            <a class="muted-link" asp-page="./Login">@TechSupportRagBot.Services.UiText.T(HttpContext, "Back to login", "Вернуться ко входу")</a>
        }
        else
        {
            <label>
                @TechSupportRagBot.Services.UiText.T(HttpContext, "Login or email", "Логин или почта")
                <input asp-for="Input.LoginOrEmail" autocomplete="username" />
            </label>
            <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Send reset link", "Отправить ссылку")</button>
            <a class="muted-link" asp-page="./Login">@TechSupportRagBot.Services.UiText.T(HttpContext, "Back to login", "Вернуться ко входу")</a>
        }

        <div asp-validation-summary="All" class="text-danger"></div>
    </form>
</div>
