@page
@model TechSupportRagBot.Areas.Identity.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "ChangePassword");
}

<div class="auth-layout">
    <form method="post" class="auth-card">
        <p class="eyebrow">Class-Engineering Suport</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "ChangePassword")</h1>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "CurrentPassword")<span class="password-field"><input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" /><button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">👁</button></span></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewPassword")<span class="password-field"><input asp-for="Input.NewPassword" type="password" autocomplete="new-password" /><button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">👁</button></span></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Repeat password")<span class="password-field"><input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" /><button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">👁</button></span></label>
        <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "SavePassword")</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>
</div>
