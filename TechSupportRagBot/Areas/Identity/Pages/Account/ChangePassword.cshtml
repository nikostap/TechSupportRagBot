@page
@model TechSupportRagBot.Areas.Identity.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Смена пароля";
}

<div class="auth-layout">
    <form method="post" class="auth-card">
        <p class="eyebrow">Class-Engineering Suport</p>
        <h1>Смена пароля</h1>
        <label>Текущий пароль<input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" /></label>
        <label>Новый пароль<input asp-for="Input.NewPassword" type="password" autocomplete="new-password" /></label>
        <label>Повтор пароля<input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" /></label>
        <button class="btn-main" type="submit">Сохранить пароль</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>
</div>
