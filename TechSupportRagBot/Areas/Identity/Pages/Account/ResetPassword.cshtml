@page
@model TechSupportRagBot.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Set password";
}

<div class="auth-layout">
    <form method="post" class="auth-card">
        <p class="eyebrow">Class-Engineering Support</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "Set new password", "Новый пароль")</h1>

        @if (Model.PasswordChanged)
        {
            <div class="notice-success">
                @TechSupportRagBot.Services.UiText.T(HttpContext, "Password changed. You can sign in now.", "Пароль изменен. Теперь можно войти.")
            </div>
            <a class="btn-main as-link" asp-page="./Login">@TechSupportRagBot.Services.UiText.T(HttpContext, "Go to login", "Перейти ко входу")</a>
        }
        else
        {
            <input type="hidden" asp-for="Input.UserId" />
            <input type="hidden" asp-for="Input.Code" />
            <label>
                @TechSupportRagBot.Services.UiText.T(HttpContext, "New password", "Новый пароль")
                <input asp-for="Input.Password" autocomplete="new-password" />
            </label>
            <label>
                @TechSupportRagBot.Services.UiText.T(HttpContext, "Repeat password", "Повтор пароля")
                <input asp-for="Input.ConfirmPassword" autocomplete="new-password" />
            </label>
            <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Save password", "Сохранить пароль")</button>
        }

        <div asp-validation-summary="All" class="text-danger"></div>
    </form>
</div>
