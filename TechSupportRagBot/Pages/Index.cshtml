@page
@model IndexModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "HeroTitle");
}

@if (User.Identity?.IsAuthenticated != true)
{
    <section class="home-hero">
        <div class="hero-panel">
            <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "HeroEyebrow")</p>
            <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "HeroTitle")</h1>
            <div class="hero-actions">
                <a class="btn-main" asp-area="Identity" asp-page="/Account/Login">@TechSupportRagBot.Services.UiText.T(HttpContext, "Login")</a>
            </div>
        </div>
    </section>
}
else
{
    <section class="page-head dashboard-head">
        <div>
            <p class="eyebrow">@Model.ProfileName</p>
            <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "Workplace")</h1>
            <p class="muted">@Model.DisplayName</p>
        </div>
        <div class="dashboard-actions">
            @if (Model.Can("CreateTickets") && Model.HasClientAccount)
            {
                <a class="btn-main as-link" asp-page="/Client/NewTicket">@TechSupportRagBot.Services.UiText.T(HttpContext, "CreateTicket")</a>
            }
            @if (Model.Can("Settings"))
            {
                <a class="btn-secondary as-link" asp-page="/Admin/Settings">@TechSupportRagBot.Services.UiText.T(HttpContext, "Settings")</a>
            }
        </div>
    </section>

    <section class="menu-tile-grid">
        @if (Model.IsInternalUser && Model.Can("ManageAdmins")) { <a asp-page="/Admin/Admins">@TechSupportRagBot.Services.UiText.T(HttpContext, "Employees")</a> }
        @if (Model.IsInternalUser && Model.Can("ManageClients")) { <a asp-page="/Admin/Clients">@TechSupportRagBot.Services.UiText.T(HttpContext, "Clients")</a> }
        @if (Model.IsInternalUser && Model.Can("ManageMachines")) { <a asp-page="/Admin/Machines">@TechSupportRagBot.Services.UiText.T(HttpContext, "Machines")</a> }
        @if (Model.IsInternalUser && Model.Can("ManageLicenses")) { <a asp-page="/Admin/Licenses">@TechSupportRagBot.Services.UiText.T(HttpContext, "Licenses")</a> }
        @if (Model.IsInternalUser && Model.Can("QA")) { <a asp-page="/Admin/BotTest">@TechSupportRagBot.Services.UiText.T(HttpContext, "BotTest", "Тест бота")</a> }
        @if (Model.IsInternalUser && Model.Can("QA")) { <a asp-page="/Admin/IndexedChats">@TechSupportRagBot.Services.UiText.T(HttpContext, "IndexedChats", "Завершённые чаты")</a> }
        @if (Model.IsInternalUser && Model.Can("QA")) { <a asp-page="/Admin/QA">QA</a> }
        @if (Model.IsInternalUser && Model.Can("Tickets")) { <a asp-page="/Admin/Tickets">@TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets")</a> }
        @if (Model.IsInternalUser && Model.Can("TimeTracking")) { <a asp-page="/Admin/TimeTracking">@TechSupportRagBot.Services.UiText.T(HttpContext, "TimeTracking")</a> }
        @if (Model.IsInternalUser && Model.Can("Settings")) { <a asp-page="/Admin/Settings">@TechSupportRagBot.Services.UiText.T(HttpContext, "Settings")</a> }
        @if (Model.IsInternalUser && Model.Can("AccessProfiles")) { <a asp-page="/Admin/AccessProfiles">@TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfiles")</a> }
        @if (Model.Can("OperatorQueue") && Model.ShowOperatorArea) { <a asp-page="/Operator/Index">@TechSupportRagBot.Services.UiText.T(HttpContext, "Operator")</a> }
        @if (Model.Can("ClientCabinet") && Model.HasClientAccount) { <a asp-page="/Client/Machines">@TechSupportRagBot.Services.UiText.T(HttpContext, "AvailableMachines")</a> }
        @if (Model.Can("ClientCabinet") && Model.HasClientAccount) { <a asp-page="/Client/Tickets">@TechSupportRagBot.Services.UiText.T(HttpContext, "MyTickets")</a> }
        @if (Model.Can("CompanyUsers") && Model.HasClientAccount) { <a asp-page="/Client/Users">@TechSupportRagBot.Services.UiText.T(HttpContext, "CompanyUsers")</a> }
    </section>

    <section class="attention-strip">
        @if (Model.IsInternalUser && Model.Can("Tickets") && Model.WaitingForOperatorCount > 0)
        {
            <a class="attention-card urgent" asp-page="/Admin/Tickets" asp-route-StatusFilter="WaitingForOperator">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "WaitingForOperator")</span>
                <strong>@Model.WaitingForOperatorCount</strong>
            </a>
        }
        @if (Model.Can("OperatorQueue") && Model.ShowOperatorArea && Model.AssignedTicketCount > 0)
        {
            <a class="attention-card" asp-page="/Operator/Index">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "AssignedTickets")</span>
                <strong>@Model.AssignedTicketCount</strong>
            </a>
        }
        @if (Model.Can("ClientCabinet") && Model.HasClientAccount && Model.UnreadMessageCount > 0)
        {
            <a class="attention-card urgent" asp-page="/Client/Tickets">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "UnreadMessages")</span>
                <strong>@Model.UnreadMessageCount</strong>
            </a>
        }
        @if (Model.IsInternalUser
            && (!Model.Can("Tickets") || Model.WaitingForOperatorCount == 0)
            && (!Model.Can("OperatorQueue") || !Model.ShowOperatorArea || Model.AssignedTicketCount == 0)
            && (!Model.Can("ClientCabinet") || !Model.HasClientAccount || Model.UnreadMessageCount == 0))
        {
            <div class="attention-card calm">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "NoUrgentItems")</span>
                <strong>OK</strong>
            </div>
        }
    </section>

    <section class="metric-grid">
        @if (Model.IsInternalUser && Model.Can("ManageClients"))
        {
            <a class="metric-card" asp-page="/Admin/Clients">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "Clients")</span>
                <strong>@Model.ClientCount</strong>
            </a>
        }
        @if (Model.IsInternalUser && Model.Can("ManageMachines"))
        {
            <a class="metric-card blue" asp-page="/Admin/Machines">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "Machines")</span>
                <strong>@Model.MachineCount</strong>
            </a>
        }
        @if (Model.IsInternalUser && Model.Can("ManageLicenses"))
        {
            <a class="metric-card cyan" asp-page="/Admin/Licenses">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "Licenses")</span>
                <strong>@Model.LicenseCount</strong>
            </a>
        }
        @if (Model.Can("ClientCabinet") && Model.HasClientAccount)
        {
            <a class="metric-card blue" asp-page="/Client/Machines">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "AvailableMachines")</span>
                <strong>@Model.AvailableMachineCount</strong>
            </a>
        }
        @if (Model.Can("CompanyUsers") && Model.HasClientAccount)
        {
            <a class="metric-card" asp-page="/Client/Users">
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "CompanyUsers")</span>
                <strong>@Model.CompanyUserCount</strong>
            </a>
        }
    </section>

    <section class="dashboard-grid">
        @if (Model.Can("OperatorQueue") && Model.ShowOperatorArea)
        {
            <div class="panel dashboard-panel">
                <div class="panel-title-row">
                    <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "AssignedTickets")</h2>
                    <a asp-page="/Operator/Index">@TechSupportRagBot.Services.UiText.T(HttpContext, "Open")</a>
                </div>
                @if (Model.AssignedTicketGroups.Count == 0)
                {
                    <p class="muted">@TechSupportRagBot.Services.UiText.T(HttpContext, "NoAssignedTickets")</p>
                }
                else
                {
                    <div class="dashboard-machine-list">
                        @foreach (var group in Model.AssignedTicketGroups)
                        {
                            <details class="dashboard-machine-group">
                                <summary>
                                    <span class="dashboard-machine-title">
                                        <strong>@group.MachineName</strong>
                                        <small>@group.MachineModel &middot; @group.TicketCount @TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets")</small>
                                    </span>
                                    @if (group.UnreadCount > 0)
                                    {
                                        <span class="unread-badge inline">+@group.UnreadCount</span>
                                    }
                                </summary>
                                <div class="dashboard-list nested">
                                    @foreach (var row in group.Rows)
                                    {
                                        <a class="dashboard-row @(row.UnreadCount > 0 ? "unread" : "")" href="@row.Url">
                                            <strong>@row.Ticket.Title</strong>
                                            <span>@(row.Ticket.ClientUser?.FullName ?? row.Ticket.ClientUser?.UserName) &middot; @Model.StatusName(row.Ticket.Status)</span>
                                            @if (row.UnreadCount > 0)
                                            {
                                                <span class="unread-badge inline">+@row.UnreadCount</span>
                                            }
                                        </a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            </div>
        }

        @if (Model.IsInternalUser && Model.Can("Tickets"))
        {
            <div class="panel dashboard-panel">
                <div class="panel-title-row">
                    <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets")</h2>
                    <a asp-page="/Admin/Tickets">@TechSupportRagBot.Services.UiText.T(HttpContext, "Open")</a>
                </div>
                @if (Model.AttentionTicketGroups.Count == 0)
                {
                    <p class="muted">@TechSupportRagBot.Services.UiText.T(HttpContext, "NoOpenTickets")</p>
                }
                else
                {
                    <div class="dashboard-machine-list">
                        @foreach (var group in Model.AttentionTicketGroups)
                        {
                            <details class="dashboard-machine-group">
                                <summary>
                                    <span class="dashboard-machine-title">
                                        <strong>@group.MachineName</strong>
                                        <small>@group.MachineModel &middot; @group.TicketCount @TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets")</small>
                                    </span>
                                    @if (group.UnreadCount > 0)
                                    {
                                        <span class="unread-badge inline">+@group.UnreadCount</span>
                                    }
                                </summary>
                                <div class="dashboard-list nested">
                                    @foreach (var row in group.Rows)
                                    {
                                        var waiting = row.Ticket.Status == TechSupportRagBot.Models.TicketStatuses.WaitingForOperator;
                                        <a class="dashboard-row @(row.UnreadCount > 0 || waiting ? "unread" : "")" href="@row.Url">
                                            <strong>@row.Ticket.Title</strong>
                                            <span>@(row.Ticket.ClientUser?.FullName ?? row.Ticket.ClientUser?.UserName) &middot; @Model.StatusName(row.Ticket.Status)</span>
                                            @if (row.UnreadCount > 0)
                                            {
                                                <span class="unread-badge inline">+@row.UnreadCount</span>
                                            }
                                        </a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            </div>
        }

        @if (Model.Can("ClientCabinet") && Model.HasClientAccount)
        {
            <div class="panel dashboard-panel">
                <div class="panel-title-row">
                    <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "MyTickets")</h2>
                    <a asp-page="/Client/Tickets">@TechSupportRagBot.Services.UiText.T(HttpContext, "Open")</a>
                </div>
                @if (Model.RecentClientTicketGroups.Count == 0)
                {
                    <p class="muted">@TechSupportRagBot.Services.UiText.T(HttpContext, "NoTicketsYet")</p>
                }
                else
                {
                    <div class="dashboard-machine-list">
                        @foreach (var group in Model.RecentClientTicketGroups)
                        {
                            <details class="dashboard-machine-group">
                                <summary>
                                    <span class="dashboard-machine-title">
                                        <strong>@group.MachineName</strong>
                                        <small>@group.MachineModel &middot; @group.TicketCount @TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets")</small>
                                    </span>
                                    @if (group.UnreadCount > 0)
                                    {
                                        <span class="unread-badge inline">+@group.UnreadCount</span>
                                    }
                                </summary>
                                <div class="dashboard-list nested">
                                    @foreach (var row in group.Rows)
                                    {
                                        <a class="dashboard-row @(row.UnreadCount > 0 ? "unread" : "")" href="@row.Url">
                                            <strong>@row.Ticket.Title</strong>
                                            <span>@Model.StatusName(row.Ticket.Status)</span>
                                            @if (row.UnreadCount > 0)
                                            {
                                                <span class="unread-badge inline">+@row.UnreadCount</span>
                                            }
                                        </a>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            </div>
        }
    </section>
}
