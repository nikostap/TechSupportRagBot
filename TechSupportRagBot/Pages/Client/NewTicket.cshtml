@page
@model TechSupportRagBot.Pages.Client.NewTicketModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "CreateTicket", "Новое обращение");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "NewQuestion", "Новый вопрос")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "CreateTicket", "Создать обращение")</h1>
    </div>
</section>

<form method="post" class="panel narrow">
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine", "Станок")
        <select asp-for="Input.MachineId" asp-items="Model.MachineOptions"></select>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Subject", "Тема")<input asp-for="Input.Title" /></label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Question", "Вопрос")<textarea asp-for="Input.Question" rows="7"></textarea></label>
    <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "OpenChat", "Открыть чат")</button>
    <div asp-validation-summary="All" class="text-danger"></div>
</form>
