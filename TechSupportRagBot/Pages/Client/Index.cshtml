@page
@model TechSupportRagBot.Pages.Client.IndexModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "Client", "Клиент");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "ClientCabinet", "Личный кабинет")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "MachineSupport", "Поддержка станков")</h1>
    </div>
    <a class="btn-main" asp-page="/Client/NewTicket">@TechSupportRagBot.Services.UiText.T(HttpContext, "CreateTicket", "Создать обращение")</a>
</section>

<div class="metric-grid">
    <a class="metric-card" asp-page="/Client/Machines">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "AvailableMachines", "Доступные станки")</span>
        <strong>@Model.AvailableMachineCount</strong>
    </a>
    <a class="metric-card" asp-page="/Client/Tickets">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "OpenTickets", "Открытые обращения")</span>
        <strong>@Model.OpenTicketCount</strong>
    </a>
    <a class="metric-card attention" asp-page="/Client/Tickets">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewMessages", "Новые сообщения")</span>
        <strong>@Model.UnreadMessageCount</strong>
    </a>
    <a class="metric-card" asp-page="/Client/Users">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "CompanyUsers", "Пользователи компании")</span>
        <strong>@Model.CompanyUserCount</strong>
    </a>
</div>

<div class="panel">
    <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "RecentTickets", "Последние обращения")</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Subject", "Тема")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine", "Станок")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Status", "Статус")</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ticket in Model.RecentTickets)
            {
                var hasUnread = Model.TicketsWithUnreadMessages.Contains(ticket.Id);
                <tr class="@(hasUnread ? "unread-row" : "")">
                    <td>
                        @if (hasUnread)
                        {
                            <span class="unread-dot" title="@TechSupportRagBot.Services.UiText.T(HttpContext, "NewMessages", "Новые сообщения")"></span>
                        }
                        @ticket.Title
                    </td>
                    <td>@ticket.Machine?.Name</td>
                    <td>@TechSupportRagBot.Services.UiText.Status(HttpContext, ticket.Status)</td>
                    <td><a asp-page="/Client/Ticket" asp-route-id="@ticket.Id">@TechSupportRagBot.Services.UiText.T(HttpContext, "Open", "Открыть")</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
