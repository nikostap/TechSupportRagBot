@page
@model TechSupportRagBot.Pages.Client.UsersModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "CompanyUsers");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "ClientCabinet")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "CompanyUsers")</h1>
    </div>
</section>

<div class="split-layout">
    <form method="post" class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewCompanyUser")</h2>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "FullName")<input asp-for="Input.FullName" /></label>
        <label>
            @TechSupportRagBot.Services.UiText.T(HttpContext, "Username")
            <input asp-for="Input.UserName" autocomplete="off" placeholder="@TechSupportRagBot.Services.UiText.T(HttpContext, "GeneratedAutomatically", "Создастся автоматически")" />
            <small class="field-hint">@TechSupportRagBot.Services.UiText.T(HttpContext, "LeaveBlankForAutomaticLogin", "Оставьте пустым — логин создастся из названия компании и ФИО")</small>
        </label>
        <label>Email<input asp-for="Input.Email" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Position")<input asp-for="Input.Position" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfile")
            <select asp-for="Input.AccessProfile">
                @foreach (var profile in Model.AccessProfileOptions)
                {
                    <option value="@profile.Key">@profile.Name</option>
                }
            </select>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")
            <select asp-for="Input.Country">
                @foreach (var language in Model.LanguageOptions)
                {
                    <option value="@language.Code">@language.Name</option>
                }
            </select>
        </label>
        <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "CreateUser")</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>

    <div class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "CompanyUsers")</h2>
        <div class="company-user-list">
        @foreach (var user in Model.Users)
        {
            <article class="company-user-card">
                <div class="company-user-avatar" aria-hidden="true">@((user.FullName ?? user.UserName ?? "U").Trim()[0].ToString().ToUpperInvariant())</div>
                <div class="company-user-identity">
                    <div class="company-user-name-row">
                        <strong>@(user.FullName ?? user.UserName)</strong>
                        @if (user.Id == Model.CurrentUserId)
                        {
                            <span class="status-pill company-user-current">@TechSupportRagBot.Services.UiText.T(HttpContext, "CurrentUser", "Текущий пользователь")</span>
                        }
                    </div>
                    <span>@@@user.UserName</span>
                    @if (!string.IsNullOrWhiteSpace(user.Position))
                    {
                        <small>@user.Position</small>
                    }
                </div>
                <dl class="company-user-meta">
                    <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Profile")</dt><dd>@TechSupportRagBot.Services.AccessProfileService.DisplayProfile(HttpContext, user.AccessProfile)</dd></div>
                    <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")</dt><dd>@TechSupportRagBot.Services.ChatTranslationService.NormalizeLanguage(user.Country)</dd></div>
                    <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "IssuedPassword")</dt><dd><code>@(user.IssuedPassword ?? TechSupportRagBot.Services.UiText.T(HttpContext, "Changed"))</code></dd></div>
                </dl>
                <div class="company-user-actions">
                    @if (user.Id != Model.CurrentUserId)
                    {
                        <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="row-action">
                            <button class="btn-danger small" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Delete")</button>
                        </form>
                    }
                </div>
            </article>
        }
        </div>
    </div>
</div>
