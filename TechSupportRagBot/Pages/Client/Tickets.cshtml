@page
@model TechSupportRagBot.Pages.Client.TicketsModel
@inject TechSupportRagBot.Services.AccessProfileService Access
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets");
    var canCreateTickets = await Access.IsAllowedAsync(User, "CreateTickets");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Support")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "MyTickets")</h1>
    </div>
    @if (canCreateTickets)
    {
        <a class="btn-main" asp-page="/Client/NewTicket">@TechSupportRagBot.Services.UiText.T(HttpContext, "CreateTicket")</a>
    }
</section>

<section class="tickets-total-bar panel client-tickets-total">
    <div>
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "TotalTickets", "Всего обращений")</span>
        <strong>@Model.TotalTicketCount</strong>
    </div>
    <div class="tickets-total-unread">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewMessages", "Новых сообщений")</span>
        <strong class="unread-badge inline">+@Model.TotalUnreadCount</strong>
    </div>
</section>

@if (Model.TicketGroups.Count == 0)
{
    <section class="panel client-tickets-empty">
        <p>@TechSupportRagBot.Services.UiText.T(HttpContext, "NoTicketsYet", "Обращений пока нет.")</p>
    </section>
}

<div class="ticket-group-list">
@foreach (var group in Model.TicketGroups)
{
    <details class="ticket-machine-group panel client-ticket-machine-group" data-details-key="machine-@group.MachineId">
        <summary class="ticket-accordion-summary machine-summary">
            <div>
                <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine")</p>
                <h2>@group.MachineName</h2>
            </div>
            <div class="ticket-summary-counts">
                @if (group.UnreadCount > 0)
                {
                    <span class="unread-badge inline">+@group.UnreadCount</span>
                }
                <span class="status-pill">@group.Rows.Count</span>
                <span class="accordion-chevron">⌄</span>
            </div>
        </summary>

        <div class="ticket-card-list">
        @foreach (var row in group.Rows)
        {
            <a class="ticket-card ticket-card-link" asp-page="/Client/Ticket" asp-route-id="@row.Ticket.Id">
                @if (row.UnreadCount > 0)
                {
                    <span class="unread-badge">+@row.UnreadCount</span>
                }
                <div class="ticket-card-main">
                    <div>
                        <h3>@row.Ticket.Title</h3>
                        <p>@row.Ticket.Machine?.Model · @row.Ticket.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                    <span class="status-pill">@TechSupportRagBot.Services.UiText.Status(HttpContext, row.Ticket.Status)</span>
                </div>
            </a>
        }
        </div>
    </details>
}
</div>

<script>
    (() => {
        const stateKey = `client-tickets:open:${location.pathname}`;
        const groups = [...document.querySelectorAll("details[data-details-key]")];
        let openKeys = new Set();
        try {
            openKeys = new Set(JSON.parse(sessionStorage.getItem(stateKey) ?? "[]"));
        } catch { }

        for (const group of groups) {
            group.open = openKeys.has(group.dataset.detailsKey);
            group.addEventListener("toggle", () => {
                sessionStorage.setItem(stateKey, JSON.stringify(
                    groups.filter(item => item.open).map(item => item.dataset.detailsKey)));
            });
        }
    })();
</script>
