@page
@model TechSupportRagBot.Pages.Client.MachinesModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "MyMachines", "Мои станки");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Equipment", "Оборудование")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "MyMachines", "Мои станки")</h1>
    </div>
    <a class="btn-main" asp-page="/Client/Activate">@TechSupportRagBot.Services.UiText.T(HttpContext, "ActivateKey", "Активировать ключ")</a>
</section>

@if (Model.Machines.Count == 0)
{
    <section class="panel client-machines-empty">
        <p>@TechSupportRagBot.Services.UiText.T(HttpContext, "NoAvailableMachines", "Нет доступных станков. Активируйте лицензионный ключ, чтобы добавить оборудование.")</p>
    </section>
}
else
{
    <div class="card-grid client-machine-grid">
    @foreach (var item in Model.Machines)
    {
        var machine = item.Machine;
        <article class="machine-card client-machine-card">
            <header class="client-machine-card-head">
                <span class="client-machine-mark" aria-hidden="true">CE</span>
                <div>
                    <span class="client-machine-type">@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine", "Станок")</span>
                    <h2>@(string.IsNullOrWhiteSpace(machine?.Name) ? "—" : machine.Name)</h2>
                </div>
            </header>

            <dl class="client-machine-details">
                <div>
                    <dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Name", "Название")</dt>
                    <dd>@(string.IsNullOrWhiteSpace(machine?.Name) ? "—" : machine.Name)</dd>
                </div>
                <div>
                    <dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Series", "Серия / модель")</dt>
                    <dd>@(string.IsNullOrWhiteSpace(machine?.Model) ? "—" : machine.Model)</dd>
                </div>
                <div>
                    <dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "SerialNumber", "Серийный номер")</dt>
                    <dd class="client-machine-serial">@(string.IsNullOrWhiteSpace(machine?.SerialNumber) ? "—" : machine.SerialNumber)</dd>
                </div>
            </dl>
        </article>
    }
    </div>
}
