@page
@model TechSupportRagBot.Pages.Operator.IndexModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "Operator");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "LineSupport")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "AssignedTickets")</h1>
    </div>
</section>

<div class="ticket-group-list">
@foreach (var group in Model.TicketGroups)
{
    <section class="ticket-group panel">
        <div class="ticket-group-head">
            <div>
                <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine")</p>
                <h2>@group.MachineName</h2>
            </div>
            <span class="status-pill">@group.Rows.Count</span>
        </div>

        <div class="ticket-card-list">
        @foreach (var row in group.Rows)
        {
            <a class="ticket-card ticket-card-link @(row.IsNewAssigned ? "new-assigned-ticket" : null)" asp-page="/Operator/Ticket" asp-route-id="@row.Ticket.Id">
                @if (row.UnreadCount > 0)
                {
                    <span class="unread-badge">+@row.UnreadCount</span>
                }
                <div class="ticket-card-main">
                    <div>
                        <h3>@row.Ticket.Title</h3>
                        <p>@(row.Ticket.ClientUser?.FullName ?? row.Ticket.ClientUser?.UserName) · @row.Ticket.Machine?.Model</p>
                    </div>
                    <span class="status-pill">@TechSupportRagBot.Services.UiText.Status(HttpContext, row.Ticket.Status)</span>
                </div>
            </a>
        }
        </div>
    </section>
}
</div>
