@page
@using System.Text.Json
@model TechSupportRagBot.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "Settings", "Настройки");

    var ollamaChatModels = Model.Models
        .Where(x => !x.IsLikelyEmbedding)
        .Select(x => x.Name)
        .Distinct()
        .ToArray();

    var ollamaEmbeddingModels = Model.Models
        .Where(x => x.IsLikelyEmbedding)
        .Select(x => x.Name)
        .Distinct()
        .ToArray();

    var openAiChatModels = new[]
    {
        "gpt-5.5",
        "gpt-5.4",
        "gpt-5.4-mini",
        "gpt-5.4-nano",
        "gpt-5",
        "gpt-5-mini",
        "gpt-5-nano",
        "gpt-4.1-mini",
        "gpt-4.1",
        "gpt-4o-mini",
        "gpt-4o"
    };

    var openAiEmbeddingModels = new[]
    {
        "text-embedding-3-small",
        "text-embedding-3-large"
    };

    var deepSeekChatModels = new[]
    {
        "deepseek-chat",
        "deepseek-reasoner"
    };
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "System", "Система")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "Settings", "Настройки")</h1>
    </div>
</section>

<div class="settings-layout">
    <form method="post" class="panel" id="rag-settings-form">
        <h2>Модели и провайдеры</h2>

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="notice-success">@Model.StatusMessage</div>
        }

        <label>Провайдер LLM
            <select asp-for="Input.ChatProvider" id="chat-provider">
                <option value="Ollama">Ollama</option>
                <option value="OpenAI">OpenAI</option>
                <option value="DeepSeek">DeepSeek</option>
            </select>
        </label>

        <label>LLM модель
            <select asp-for="Input.ChatModel" id="chat-model"></select>
        </label>

        <label>Провайдер embeddings
            <select asp-for="Input.EmbeddingProvider" id="embedding-provider">
                <option value="Ollama">Ollama</option>
                <option value="OpenAI">OpenAI</option>
            </select>
        </label>

        <label>Embedding модель
            <select asp-for="Input.EmbeddingModel" id="embedding-model"></select>
        </label>

        @if (Model.Models.Count == 0)
        {
            <div class="notice-soft" data-provider-note="Ollama">
                Ollama не вернул список моделей. Это нормально, если выбран OpenAI или DeepSeek. Для Ollama проверьте, что сервис запущен и доступен приложению.
            </div>
        }

        @if (!Model.HasOpenAiKey)
        {
            <div class="notice-soft" data-provider-note="OpenAI">
                OpenAI API key не задан. Укажите переменную окружения <code>OpenAI__ApiKey</code>.
            </div>
        }

        @if (!Model.HasDeepSeekKey)
        {
            <div class="notice-soft" data-provider-note="DeepSeek">
                DeepSeek API key не задан. Укажите переменную окружения <code>DeepSeek__ApiKey</code>.
            </div>
        }

        <h2>Почтовые уведомления</h2>
        <label>Отправлять письмо, если сообщение не прочитано, минут
            <input asp-for="Input.UnreadEmailDelayMinutes" type="number" min="5" max="1440" step="5" />
        </label>

        <button class="btn-main" type="submit">Сохранить</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>

    <section class="panel">
        <h2>Доступы сотрудников</h2>
        <p>Настройка профилей: менеджер, оператор, программист, администратор, наблюдатель.</p>
        <a class="btn-main as-link" asp-page="/Admin/AccessProfiles">Открыть профили доступа</a>
    </section>

    <section class="panel">
        <h2>Модели Ollama</h2>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Модель</th>
                        <th>Тип</th>
                        <th>Размер</th>
                        <th>Обновлена</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Models.Count == 0)
                {
                    <tr>
                        <td colspan="4">Список моделей Ollama недоступен.</td>
                    </tr>
                }
                @foreach (var item in Model.Models)
                {
                    <tr>
                        <td><code>@item.Name</code></td>
                        <td>@(item.IsLikelyEmbedding ? "Embedding" : "LLM")</td>
                        <td>@TechSupportRagBot.Pages.Admin.SettingsModel.FormatSize(item.Size)</td>
                        <td>@(item.ModifiedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>

<script>
    (() => {
        const models = {
            chat: {
                Ollama: @Html.Raw(JsonSerializer.Serialize(ollamaChatModels)),
                OpenAI: @Html.Raw(JsonSerializer.Serialize(openAiChatModels)),
                DeepSeek: @Html.Raw(JsonSerializer.Serialize(deepSeekChatModels))
            },
            embedding: {
                Ollama: @Html.Raw(JsonSerializer.Serialize(ollamaEmbeddingModels)),
                OpenAI: @Html.Raw(JsonSerializer.Serialize(openAiEmbeddingModels))
            }
        };

        const current = {
            chatModel: @Html.Raw(JsonSerializer.Serialize(Model.Input.ChatModel)),
            embeddingModel: @Html.Raw(JsonSerializer.Serialize(Model.Input.EmbeddingModel))
        };

        const fallback = {
            chat: {
                Ollama: "llama3.1",
                OpenAI: "gpt-5.4-mini",
                DeepSeek: "deepseek-chat"
            },
            embedding: {
                Ollama: "embeddinggemma",
                OpenAI: "text-embedding-3-small"
            }
        };

        function fillSelect(select, values, selectedValue, fallbackValue) {
            select.innerHTML = "";

            const normalizedValues = [...new Set(values.filter(x => x && x.trim()))];
            if (selectedValue && !normalizedValues.includes(selectedValue)) {
                normalizedValues.unshift(selectedValue);
            }

            if (normalizedValues.length === 0 && fallbackValue) {
                normalizedValues.push(fallbackValue);
            }

            for (const value of normalizedValues) {
                const option = document.createElement("option");
                option.value = value;
                option.textContent = value;
                select.appendChild(option);
            }

            select.value = selectedValue && normalizedValues.includes(selectedValue)
                ? selectedValue
                : normalizedValues[0] ?? "";
        }

        function refreshChatModels() {
            const provider = document.getElementById("chat-provider").value;
            const select = document.getElementById("chat-model");
            const selected = select.value || current.chatModel;
            fillSelect(select, models.chat[provider] ?? [], selected, fallback.chat[provider]);
            current.chatModel = select.value;
        }

        function refreshEmbeddingModels() {
            const provider = document.getElementById("embedding-provider").value;
            const select = document.getElementById("embedding-model");
            const selected = select.value || current.embeddingModel;
            fillSelect(select, models.embedding[provider] ?? [], selected, fallback.embedding[provider]);
            current.embeddingModel = select.value;
        }

        document.getElementById("chat-provider").addEventListener("change", () => {
            current.chatModel = "";
            refreshChatModels();
        });

        document.getElementById("embedding-provider").addEventListener("change", () => {
            current.embeddingModel = "";
            refreshEmbeddingModels();
        });

        refreshChatModels();
        refreshEmbeddingModels();
    })();
</script>
