@page
@model TechSupportRagBot.Pages.Admin.AccessProfilesModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfiles");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Settings")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfiles")</h1>
    </div>
    <a class="btn-secondary as-link" asp-page="/Admin/Settings">@TechSupportRagBot.Services.UiText.T(HttpContext, "BackToSettings")</a>
</section>

<form method="post" class="panel">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="notice-success">@Model.StatusMessage</div>
    }

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Function")</th>
                    @foreach (var profile in Model.Profiles)
                    {
                        <th>@profile.Name</th>
                    }
                </tr>
            </thead>
            <tbody>
            @foreach (var permission in Model.Permissions)
            {
                <tr>
                    <td>@permission.Name</td>
                    @foreach (var profile in Model.Profiles)
                    {
                        var inputName = $"perm_{profile.Key}_{permission.Key}";
                        var enabled = profile.Permissions.TryGetValue(permission.Key, out var allowed) && allowed;
                        <td>
                            <label class="check-line compact-check">
                                <input type="checkbox" name="@inputName" checked="@enabled" />
                                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "EnabledShort")</span>
                            </label>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>

    <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "SavePermissions")</button>
</form>
