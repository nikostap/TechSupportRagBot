@page "{id}"
@model TechSupportRagBot.Pages.Admin.UserProfileModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "Profile");
    var isClient = Model.EditedUser?.ClientId != null;
}

<section class="page-head">
    <div>
        <p class="eyebrow">@string.Join(", ", Model.Roles)</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "Profile")</h1>
    </div>
    <a class="btn-secondary as-link" href="javascript:history.back()">@TechSupportRagBot.Services.UiText.T(HttpContext, "Back")</a>
</section>

<div class="profile-admin-layout">
    <section class="panel profile-card">
        <div class="profile-head">
            @if (!string.IsNullOrWhiteSpace(Model.EditedUser?.AvatarPath))
            {
                <img class="avatar avatar-large" src="/@Model.EditedUser.AvatarPath.Replace("\\", "/")" alt="avatar" />
            }
            else
            {
                <div class="avatar avatar-large">@Model.Initials</div>
            }
            <div>
                <h2>@Model.EditedUser?.FullName</h2>
                <p>@Model.EditedUser?.UserName</p>
            </div>
        </div>

        <dl class="profile-details">
            <div><dt>Email</dt><dd>@(Model.EditedUser?.Email ?? "—")</dd></div>
            <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Position")</dt><dd>@(Model.EditedUser?.Position ?? "—")</dd></div>
            <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfile")</dt><dd>@TechSupportRagBot.Services.AccessProfileService.DisplayProfile(HttpContext, Model.EditedUser?.AccessProfile)</dd></div>
            <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")</dt><dd>@TechSupportRagBot.Services.ChatTranslationService.NormalizeLanguage(Model.EditedUser?.Country)</dd></div>
            <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "Gender")</dt><dd>@(Model.EditedUser?.Gender ?? "—")</dd></div>
            <div><dt>@TechSupportRagBot.Services.UiText.T(HttpContext, "IssuedPassword")</dt><dd><code>@(Model.EditedUser?.IssuedPassword ?? TechSupportRagBot.Services.UiText.T(HttpContext, "Changed"))</code></dd></div>
        </dl>
    </section>

    <form method="post" asp-page-handler="Save" class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "EditProfile")</h2>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "FullName")<input asp-for="Input.FullName" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Username")<input asp-for="Input.UserName" /></label>
        <label>Email<input asp-for="Input.Email" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Position")<input asp-for="Input.Position" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfile")
            <select asp-for="Input.AccessProfile">
                @foreach (var profile in Model.AccessProfileOptions)
                {
                    <option value="@profile.Key">@profile.Name</option>
                }
            </select>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")
            <select asp-for="Input.Country">
                @foreach (var language in Model.LanguageOptions)
                {
                    <option value="@language.Code">@language.Name</option>
                }
            </select>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Gender")
            <select asp-for="Input.Gender">
                <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "NotSpecified")</option>
                <option value="Мужской">@TechSupportRagBot.Services.UiText.T(HttpContext, "Male")</option>
                <option value="Женский">@TechSupportRagBot.Services.UiText.T(HttpContext, "Female")</option>
            </select>
        </label>
        @if (isClient)
        {
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Company")<input asp-for="Input.CompanyName" /></label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Phone")<input asp-for="Input.Phone" /></label>
        }
        <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Save")</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>

    <form method="post" asp-page-handler="ResetPassword" class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "Password")</h2>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewPassword")<input name="password" autocomplete="new-password" /></label>
        <button class="btn-secondary" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "SetPassword")</button>
    </form>
</div>
