@page
@model TechSupportRagBot.Pages.Admin.AdminsModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "Employees");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Administration")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "Employees")</h1>
    </div>
</section>

<div class="split-layout">
    <form method="post" class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewEmployee")</h2>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "FullName")<input asp-for="Input.FullName" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Username")<input asp-for="Input.UserName" autocomplete="off" /></label>
        <label>Email<input asp-for="Input.Email" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Position")<input asp-for="Input.Position" /></label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "AccessProfile")
            <select asp-for="Input.AccessProfile">
                @foreach (var profile in Model.AccessProfileOptions)
                {
                    <option value="@profile.Key">@profile.Name</option>
                }
            </select>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")
            <select asp-for="Input.Country">
                @foreach (var language in Model.LanguageOptions)
                {
                    <option value="@language.Code">@language.Name</option>
                }
            </select>
        </label>
        <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "CreateEmployee")</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>

    <div class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "Employees")</h2>
        <div class="table-wrap">
            <table class="employee-accounts-table">
                <thead>
                    <tr>
                        <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "FullName")</th>
                        <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Username")</th>
                        <th>Email</th>
                        <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "TemporaryPassword")</th>
                        <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Position")</th>
                        <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Profile")</th>
                        <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Admins)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td><code>@user.UserName</code></td>
                        <td>@user.Email</td>
                        <td><code>@(user.IssuedPassword ?? TechSupportRagBot.Services.UiText.T(HttpContext, "Changed"))</code></td>
                        <td>@user.Position</td>
                        <td>@TechSupportRagBot.Services.AccessProfileService.DisplayProfile(HttpContext, user.AccessProfile)</td>
                        <td>@TechSupportRagBot.Services.ChatTranslationService.NormalizeLanguage(user.Country)</td>
                        <td class="table-actions">
                            <a class="btn-secondary as-link" asp-page="/Admin/UserProfile" asp-route-id="@user.Id">@TechSupportRagBot.Services.UiText.T(HttpContext, "Profile")</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="row-action">
                                <button class="btn-danger" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Delete")</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
