        <option value="@machine.Model"></option>
    }
</datalist>

<datalist id="qa-serials-create"></datalist>
<datalist id="qa-serials-edit"></datalist>
@functions {
    private string Display(string? value) => string.IsNullOrWhiteSpace(value) ? TechSupportRagBot.Services.UiText.T(ViewContext.HttpContext, "NotSpecified") : value;
    private static string FileUrl(string? path) => string.IsNullOrWhiteSpace(path) ? "" : "/" + path.Replace("\\", "/").TrimStart('/');
    private static bool IsVideo(TechSupportRagBot.Models.QAAttachment attachment)
    {
        var extension = System.IO.Path.GetExtension(attachment.OriginalFileName).ToLowerInvariant();
        return attachment.ContentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase)
            || extension is ".mp4" or ".mov" or ".webm" or ".mkv";
    }
}

<script>
(() => {
    const machines = @Html.Raw(Model.MachineHintsJson);

    function normalize(value) {
        return (value || "").trim().toLowerCase();
    }

    function refreshSerialHints(modelInputId, datalistId) {
        const modelInput = document.getElementById(modelInputId);
        const list = document.getElementById(datalistId);
        if (!modelInput || !list) {
            return;
        }

        const model = normalize(modelInput.value);
        list.innerHTML = "";
        if (!model) {
            return;
        }

        const serials = machines
            .filter(x => x.serialNumber && normalize(x.model) === model)
            .filter((x, index, all) => all.findIndex(y => y.serialNumber === x.serialNumber) === index);

        for (const machine of serials) {
            const option = document.createElement("option");
            option.value = machine.serialNumber;
            option.label = `${machine.model || ""} · ${machine.name || ""}`.trim();
            list.appendChild(option);
        }
    }

    function bind(modelInputId, datalistId) {
        const modelInput = document.getElementById(modelInputId);
        if (!modelInput) {
            return;
        }

        const update = () => refreshSerialHints(modelInputId, datalistId);
        modelInput.addEventListener("input", update);
        modelInput.addEventListener("change", update);
        update();
    }

    bind("Input_MachineModel", "qa-serials-create");
    bind("EditInput_MachineModel", "qa-serials-edit");

    document.querySelectorAll(".qa-import-model[data-serial-list]").forEach(modelInput => {
        const listId = modelInput.dataset.serialList;
        const update = () => refreshSerialHints(modelInput.id || assignId(modelInput), listId);
        if (!modelInput.id) {
            assignId(modelInput);
        }
        modelInput.addEventListener("input", update);
        modelInput.addEventListener("change", update);
        update();
    });

    function assignId(element) {
        element.id = `qa-model-${Math.random().toString(36).slice(2)}`;
        return element.id;
    }
})();
</script>

