            @for (var i = 0; i < Model.PreviewEntries.Count; i++)
            {
                <article class="qa-card">
                    <label class="check-row">
                        <input name="ConfirmEntries[@i].ImportSelected" type="checkbox" value="true" checked />
                        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "ImportThis")</span>
                    </label>
                    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Question")
                        <input name="ConfirmEntries[@i].Question" value="@Model.PreviewEntries[i].Question" />
                    </label>
                    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Answer")
                        <textarea name="ConfirmEntries[@i].Answer" rows="4">@Model.PreviewEntries[i].Answer</textarea>
                    </label>
                    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "AlternativeQuestions")
                        <textarea name="ConfirmEntries[@i].AlternativeQuestions" rows="3">@Model.PreviewEntries[i].AlternativeQuestions</textarea>
                    </label>
                    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Keywords")
                        <input name="ConfirmEntries[@i].Keywords" value="@Model.PreviewEntries[i].Keywords" />
                    </label>
                    <div class="inline-grid">
                        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Category")
                            <input name="ConfirmEntries[@i].Category" value="@Model.PreviewEntries[i].Category" />
                        </label>
                        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Model")
                            <input class="qa-import-model" name="ConfirmEntries[@i].MachineModel" value="@Model.PreviewEntries[i].MachineModel" list="qa-models" data-serial-list="qa-serials-import-@i" />
                        </label>
                        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "SerialNumberRange")
                            <input name="ConfirmEntries[@i].SerialNumber" value="@Model.PreviewEntries[i].SerialNumber" list="qa-serials-import-@i" placeholder="5-30" />
                            <datalist id="qa-serials-import-@i"></datalist>
                        </label>
                        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Node")
                            <input name="ConfirmEntries[@i].NodeName" value="@Model.PreviewEntries[i].NodeName" />
                        </label>
                        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "ProblemType")
                            <input name="ConfirmEntries[@i].ProblemType" value="@Model.PreviewEntries[i].ProblemType" />
                        </label>
