@page
@model TechSupportRagBot.Pages.Admin.QAModel
@{
    ViewData["Title"] = "QA";
}

<section class="page-head">
    <div>
        <p class="eyebrow">RAG</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "QA")</h1>
    </div>
    <div class="page-actions">
        <a class="btn-secondary" asp-page-handler="TemplateTxt">@TechSupportRagBot.Services.UiText.T(HttpContext, "DownloadTxt")</a>
        <a class="btn-secondary" asp-page-handler="TemplateDocx">@TechSupportRagBot.Services.UiText.T(HttpContext, "DownloadDocx")</a>
    </div>
</section>

@if (Model.EditId.HasValue)
{
    <form method="post" enctype="multipart/form-data" class="panel qa-editor">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "EditQA")</h2>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Question")
            <textarea asp-for="EditInput.Question" rows="3"></textarea>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Answer")
            <textarea asp-for="EditInput.Answer" rows="7"></textarea>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "AlternativeQuestions")
            <textarea asp-for="EditInput.AlternativeQuestions" rows="3"></textarea>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Keywords")
            <input asp-for="EditInput.Keywords" />
        </label>
        <div class="inline-grid">
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Category")
                <input asp-for="EditInput.Category" list="qa-categories" />
            </label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Model")
                <input asp-for="EditInput.MachineModel" list="qa-models" placeholder="@TechSupportRagBot.Services.UiText.T(HttpContext, "Model")" />
            </label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "SerialNumberRange")
                <input asp-for="EditInput.SerialNumber" list="qa-serials-edit" placeholder="5-30" />
                <small class="muted-text">@TechSupportRagBot.Services.UiText.T(HttpContext, "QASerialHelp")</small>
            </label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Node")
                <input asp-for="EditInput.NodeName" />
            </label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "ProblemType")
                <input asp-for="EditInput.ProblemType" />
            </label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Status")
                <select asp-for="EditInput.Status">
                    @foreach (var status in Model.Statuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </label>
        </div>
        <input type="hidden" asp-for="EditInput.Source" />
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "MediaForAnswer")
            <span class="file-picker">
                <input asp-for="EditMediaFiles" type="file" multiple accept="image/*,video/*" />
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "ChooseMedia")</span>
            </span>
            <small class="muted-text">@TechSupportRagBot.Services.UiText.T(HttpContext, "QAMediaEditHelp")</small>
        </label>
        @if (Model.EditAttachments.Count > 0)
        {
            <div class="qa-media-grid">
                @foreach (var media in Model.EditAttachments)
                {
                    <article class="qa-media-item">
                        @if (IsVideo(media))
                        {
                            <video controls src="@FileUrl(media.FilePath)"></video>
                        }
                        else
                        {
                            <img src="@FileUrl(media.FilePath)" alt="@media.OriginalFileName" />
                        }
                        <span>@media.OriginalFileName</span>
                        <button class="btn-danger small" type="submit" asp-page-handler="DeleteAttachment" asp-route-id="@Model.EditId" asp-route-attachmentId="@media.Id">@TechSupportRagBot.Services.UiText.T(HttpContext, "DeleteFile")</button>
                    </article>
                }
            </div>
        }
        <div class="form-actions">
            <button class="btn-secondary" type="submit" asp-page-handler="PreviewEditMetadata" asp-route-id="@Model.EditId">@TechSupportRagBot.Services.UiText.T(HttpContext, "QAMetadataLlm")</button>
            <button class="btn-main" type="submit" asp-page-handler="Update" asp-route-id="@Model.EditId">@TechSupportRagBot.Services.UiText.T(HttpContext, "SaveAndReindex")</button>
            <a class="btn-secondary" asp-page="/Admin/QA">@TechSupportRagBot.Services.UiText.T(HttpContext, "Cancel")</a>
        </div>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>
}

