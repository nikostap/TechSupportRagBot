@page
@model TechSupportRagBot.Pages.Admin.BotTestModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "BotTest", "Тест бота");
}

<section class="page-head">
    <div>
        <p class="eyebrow">RAG</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "BotTest", "Тест бота")</h1>
    </div>
</section>

<section class="panel">
    <form id="botTestForm" method="post" asp-page-handler="Ask" class="form-grid bot-test-form">
        <div>
            <label asp-for="Input.MachineId">@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine")</label>
            <select asp-for="Input.MachineId" asp-items="Model.MachineOptions" required data-required-message="@TechSupportRagBot.Services.UiText.T(HttpContext, "MachineRequired")">
                <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "SelectMachine", "Выберите станок")</option>
            </select>
            <span asp-validation-for="Input.MachineId" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.Language">@TechSupportRagBot.Services.UiText.T(HttpContext, "AnswerLanguage", "Язык ответа")</label>
            <select asp-for="Input.Language" asp-items="Model.LanguageOptions"></select>
        </div>

        <div class="full-span">
            <label asp-for="Input.Question">@TechSupportRagBot.Services.UiText.T(HttpContext, "Question")</label>
            <textarea asp-for="Input.Question" rows="4" required data-required-message="@TechSupportRagBot.Services.UiText.T(HttpContext, "QuestionRequired")" placeholder="Например: Как настроить щелевой датчик на аппликаторе?"></textarea>
            <span asp-validation-for="Input.Question" class="text-danger"></span>
        </div>

        <div class="form-actions full-span">
            <button class="btn-secondary" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "AskBot", "Спросить бота")</button>
        </div>
    </form>
</section>

@if (Model.BotAnswer is not null)
{
    <section class="panel bot-test-result">
        <div class="section-bar">
            <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "BotAnswer", "Ответ бота")</h2>
        </div>
        <div class="chat-bubble bot">
            @foreach (var paragraph in Model.BotAnswer.Text.Split("\n\n", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                <p>@paragraph</p>
            }
        </div>

        @if (Model.BotAnswer.Media.Count > 0)
        {
            <div class="qa-media-grid">
                @foreach (var media in Model.BotAnswer.Media)
                {
                    if (media.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                    {
                        <img src="@media.FilePath" alt="@media.OriginalFileName" />
                    }
                    else if (media.ContentType.StartsWith("video/", StringComparison.OrdinalIgnoreCase))
                    {
                        <video src="@media.FilePath" controls></video>
                    }
                }
            </div>
        }
    </section>
}

@if (Model.SearchResult is not null)
{
    <section class="panel bot-test-debug">
        <div class="section-bar">
            <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "SearchDiagnostics", "Диагностика поиска")</h2>
        </div>

        <div class="indexed-chat-grid">
            <div>
                <span class="muted-text">@TechSupportRagBot.Services.UiText.T(HttpContext, "RussianRetrievalQuestion", "Русский поисковый запрос")</span>
                <strong>@Model.RetrievalQuestion</strong>
            </div>
            <div>
                <span class="muted-text">Intent</span>
                <strong>@Model.SearchResult.Debug.QueryIntent</strong>
            </div>
            <div>
                <span class="muted-text">Confidence</span>
                <strong>@Model.SearchResult.Confidence.ToString("F3")</strong>
            </div>
            <div>
                <span class="muted-text">ShouldCallOperator</span>
                <strong>@Model.SearchResult.ShouldCallOperator</strong>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SearchResult.Warning))
        {
            <p class="alert-warning">@Model.SearchResult.Warning</p>
        }

        <h3>@TechSupportRagBot.Services.UiText.T(HttpContext, "SelectedChunks", "Выбранные чанки")</h3>
        <div class="qa-compact-list">
            @foreach (var chunk in Model.SearchResult.Chunks)
            {
                <details class="qa-compact-card">
                    <summary class="qa-card-summary">
                        <span class="qa-summary-main">
                            <strong>#@chunk.ChunkId · @(chunk.DocumentType ?? chunk.SourceType)</strong>
                            <small>@(chunk.DocumentName ?? chunk.FileName ?? chunk.Title ?? "Источник без названия")</small>
                        </span>
                        <span class="status-pill">score @chunk.RerankScore.ToString("F3")</span>
                    </summary>
                    <div class="qa-card-body">
                        <div class="indexed-chat-grid">
                            <div><span class="muted-text">Category</span><strong>@(chunk.Category ?? "-")</strong></div>
                            <div><span class="muted-text">MachineModel</span><strong>@(chunk.MachineModel ?? "-")</strong></div>
                            <div><span class="muted-text">Serial</span><strong>@(chunk.SerialNumber ?? "-")</strong></div>
                            <div><span class="muted-text">Section</span><strong>@(chunk.SectionTitle ?? "-")</strong></div>
                            <div><span class="muted-text">Dense</span><strong>@chunk.DenseScore.ToString("F3")</strong></div>
                            <div><span class="muted-text">Keyword</span><strong>@chunk.KeywordScore.ToString("F3")</strong></div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(chunk.RetrievalReason))
                        {
                            <p class="muted-text">@chunk.RetrievalReason</p>
                        }
                        <pre class="debug-pre">@chunk.Text</pre>
                    </div>
                </details>
            }
        </div>

        <h3>@TechSupportRagBot.Services.UiText.T(HttpContext, "ContextSentToLlm", "Контекст, который ушёл в LLM")</h3>
        <pre class="debug-pre">@Model.ContextForLlm</pre>
    </section>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll("#botTestForm [data-required-message]").forEach((field) => {
            const clearError = () => field.setCustomValidity("");
            field.addEventListener("input", clearError);
            field.addEventListener("change", clearError);
            field.addEventListener("invalid", () => field.setCustomValidity(field.dataset.requiredMessage));
        });
    </script>
}
