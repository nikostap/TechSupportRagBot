@page
@model TechSupportRagBot.Pages.Admin.TimeTrackingModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "TimeTracking");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Operators")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "TimeTracking")</h1>
    </div>
</section>

<form method="get" class="panel time-filter">
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "TimeFrom")
        <input asp-for="DateFrom" type="date" />
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "TimeTo")
        <input asp-for="DateTo" type="date" />
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Period")
        <select asp-for="Period">
            <option value="day">@TechSupportRagBot.Services.UiText.T(HttpContext, "PeriodDay")</option>
            <option value="month">@TechSupportRagBot.Services.UiText.T(HttpContext, "PeriodMonth")</option>
            <option value="year">@TechSupportRagBot.Services.UiText.T(HttpContext, "PeriodYear")</option>
        </select>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Operator")
        <select asp-for="OperatorId" asp-items="Model.OperatorOptions">
            <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "AllOperators")</option>
        </select>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Model")
        <select asp-for="MachineModel" asp-items="Model.MachineModelOptions">
            <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "AllModels")</option>
        </select>
    </label>
    <button class="btn-secondary small" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Show")</button>
</form>

<div class="metric-grid">
    <div class="metric-card blue">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "WorkingTime")</span>
        <strong>@TimeTrackingModel.FormatDuration(Model.TotalWorkSeconds)</strong>
    </div>
    <div class="metric-card attention">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "OvertimeHours")</span>
        <strong>@TimeTrackingModel.FormatDuration(Model.TotalOvertimeSeconds)</strong>
    </div>
    <div class="metric-card cyan">
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "Total")</span>
        <strong>@TimeTrackingModel.FormatDuration(Model.TotalWorkSeconds + Model.TotalOvertimeSeconds)</strong>
    </div>
</div>

<div class="split-layout">
    <section class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "EmployeeComparison")</h2>
        <div class="bar-list">
            @foreach (var row in Model.OperatorChart)
            {
                <div class="bar-row">
                    <div class="bar-label">
                        <strong>@row.Name</strong>
                        <span>@TimeTrackingModel.FormatDuration(row.TotalSeconds)</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill" style="width: @Model.Percent(row.TotalSeconds, Model.MaxOperatorSeconds)%"></div>
                        @if (row.OvertimeSeconds > 0)
                        {
                            <div class="bar-fill overtime" style="width: @Model.Percent(row.OvertimeSeconds, Model.MaxOperatorSeconds)%"></div>
                        }
                    </div>
                </div>
            }
            @if (Model.OperatorChart.Count == 0)
            {
                <p class="muted-text">@TechSupportRagBot.Services.UiText.T(HttpContext, "NoActivityForSelectedPeriod")</p>
            }
        </div>
    </section>

    <section class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "MachineModels")</h2>
        <div class="bar-list">
            @foreach (var row in Model.MachineChart)
            {
                <div class="bar-row">
                    <div class="bar-label">
                        <strong>@row.Name</strong>
                        <span>@TimeTrackingModel.FormatDuration(row.TotalSeconds)</span>
                    </div>
                    <div class="bar-track">
                        <div class="bar-fill cyan" style="width: @Model.Percent(row.TotalSeconds, Model.MaxMachineSeconds)%"></div>
                    </div>
                </div>
            }
            @if (Model.MachineChart.Count == 0)
            {
                <p class="muted-text">@TechSupportRagBot.Services.UiText.T(HttpContext, "NoActivityForSelectedPeriod")</p>
            }
        </div>
    </section>
</div>

<section class="panel">
    <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "DetailsReport")</h2>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Period")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Operator")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Model")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Tickets")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "WorkingTime")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Overtime")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Total")</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr class="@(row.OvertimeSeconds > 0 ? "overtime-row" : "")">
                    <td>@row.Period</td>
                    <td>@row.OperatorName</td>
                    <td>@row.MachineModel</td>
                    <td>@row.TicketCount</td>
                    <td>@TimeTrackingModel.FormatDuration(row.WorkSeconds)</td>
                    <td>@TimeTrackingModel.FormatDuration(row.OvertimeSeconds)</td>
                    <td>@TimeTrackingModel.FormatDuration(row.TotalSeconds)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
