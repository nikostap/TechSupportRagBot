@page
@model TechSupportRagBot.Pages.Admin.KnowledgeModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "KnowledgeBase", "База знаний");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "RagLibrary", "RAG-библиотека")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "KnowledgeBase", "База знаний")</h1>
    </div>
</section>

<div class="knowledge-layout">
    <form method="post" enctype="multipart/form-data" class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "UploadDocument", "Загрузить документ")</h2>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "File", "Файл")
            <span class="file-picker">
                <input asp-for="Input.File" type="file" accept=".pdf,.docx,.txt,.xlsx,.xls" />
                <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "ChooseFile", "Выберите файл")</span>
            </span>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Category", "Категория")
            <select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions">
                <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "SelectCategory", "Выберите категорию")</option>
            </select>
        </label>
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine", "Станок")
            <select asp-for="Input.MachineId" asp-items="Model.MachineOptions">
                <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "AllMachines", "Для всех станков")</option>
            </select>
        </label>
        <label>Серийный номер или диапазон
            <input asp-for="Input.SerialNumber" list="knowledge-serials" placeholder="Например 5-30 или SN-2024-001" />
            <small class="muted-text">Например 5-30 значит, что информация относится ко всем серийным номерам в этом диапазоне.</small>
        </label>
        <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "UploadIndex", "Загрузить и проиндексировать")</button>
        <div asp-validation-summary="All" class="text-danger"></div>
    </form>

    <div class="panel">
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "Categories", "Категории")</h2>
        <form method="post" asp-page-handler="AddCategory" class="inline-add">
            <input asp-for="NewCategoryName" placeholder="@TechSupportRagBot.Services.UiText.T(HttpContext, "NewCategory", "Новая категория")" />
            <button class="btn-secondary" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Add", "Добавить")</button>
        </form>

        <div class="category-list">
            @foreach (var category in Model.Categories)
            {
                <div class="category-item">
                    <span>@category.Name</span>
                    <form method="post" asp-page-handler="DeleteCategory" asp-route-id="@category.Id">
                        <button class="icon-danger" type="submit" title="@TechSupportRagBot.Services.UiText.T(HttpContext, "Delete", "Удалить")">×</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

<datalist id="knowledge-serials">
    @foreach (var machine in Model.MachineSerialOptions)
    {
        <option value="@machine.SerialNumber">@machine.Model · @machine.Name</option>
    }
</datalist>

<script>
(() => {
    const machines = @Html.Raw(Model.MachineHintsJson);
    const machineSelect = document.getElementById("Input_MachineId");
    const serialInput = document.getElementById("Input_SerialNumber");
    if (!machineSelect || !serialInput) {
        return;
    }

    machineSelect.addEventListener("change", () => {
        const id = Number(machineSelect.value);
        const machine = machines.find(x => x.id === id);
        if (machine?.serialNumber) {
            serialInput.value = machine.serialNumber;
        } else {
            serialInput.value = "";
        }
    });
})();
</script>

<div class="panel">
    <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "Documents", "Документы")</h2>
    <form method="get" class="knowledge-filter">
        <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine", "Станок")
            <select asp-for="FilterMachineId" asp-items="Model.MachineOptions">
                <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "AllMachines", "Все станки")</option>
            </select>
        </label>
        <button class="btn-secondary small" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Show", "Показать")</button>
    </form>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "File", "Файл")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Category", "Категория")</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Machine", "Станок")</th>
                    <th>Серийный номер / диапазон</th>
                    <th>@TechSupportRagBot.Services.UiText.T(HttpContext, "Status", "Статус")</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var document in Model.Documents)
            {
                <tr>
                    <td>@document.OriginalFileName</td>
                    <td>@document.Category</td>
                    <td>@(document.AppliesToAllMachines ? TechSupportRagBot.Services.UiText.T(HttpContext, "AllMachines", "Для всех станков") : document.Machine?.Name)</td>
                    <td>@(string.IsNullOrWhiteSpace(document.SerialNumber) ? "Любой" : document.SerialNumber)</td>
                    <td><span class="status-pill">@document.Status</span></td>
                    <td class="table-actions">
                        <form method="post" asp-page-handler="DeleteDocument" asp-route-id="@document.Id" class="row-action">
                            <button class="btn-danger" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Delete", "Удалить")</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="pagination">
        @if (Model.PageNumber > 1)
        {
            <a class="btn-secondary" asp-route-PageNumber="@(Model.PageNumber - 1)" asp-route-FilterMachineId="@Model.FilterMachineId">@TechSupportRagBot.Services.UiText.T(HttpContext, "Previous", "Назад")</a>
        }
        <span>@Model.PageNumber / @Model.TotalPages</span>
        @if (Model.PageNumber < Model.TotalPages)
        {
            <a class="btn-secondary" asp-route-PageNumber="@(Model.PageNumber + 1)" asp-route-FilterMachineId="@Model.FilterMachineId">@TechSupportRagBot.Services.UiText.T(HttpContext, "Next", "Вперед")</a>
        }
    </div>
</div>
