@page
@model TechSupportRagBot.Pages.ProfileEditModel
@{
    ViewData["Title"] = TechSupportRagBot.Services.UiText.T(HttpContext, "EditProfile");
}

<section class="page-head">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Account")</p>
        <h1>@TechSupportRagBot.Services.UiText.T(HttpContext, "EditProfile")</h1>
    </div>
    <a class="btn-secondary as-link" asp-page="/Profile">@TechSupportRagBot.Services.UiText.T(HttpContext, "Back")</a>
</section>

<form method="post" enctype="multipart/form-data" asp-page-handler="Save" class="panel narrow">
    <div class="profile-head">
        @if (!string.IsNullOrWhiteSpace(Model.CurrentAvatarPath))
        {
            <img class="avatar avatar-large" id="avatarPreviewImage" src="/@Model.CurrentAvatarPath.Replace("\\", "/")" alt="avatar" />
        }
        else
        {
            <div class="avatar avatar-large" id="avatarPreviewInitials">@Model.Initials</div>
        }
        <div>
            <h2>@Model.FullName</h2>
            <p>@Model.UserName</p>
        </div>
    </div>

    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "FullName")<input asp-for="Input.FullName" /></label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Position")<input asp-for="Input.Position" /></label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Language")
        <select asp-for="Input.Language">
            @foreach (var language in Model.LanguageOptions)
            {
                <option value="@language.Code">@language.Name</option>
            }
        </select>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Gender")
        <select asp-for="Input.Gender">
            <option value="">@TechSupportRagBot.Services.UiText.T(HttpContext, "NotSpecified")</option>
            <option value="Мужской">@TechSupportRagBot.Services.UiText.T(HttpContext, "Male")</option>
            <option value="Женский">@TechSupportRagBot.Services.UiText.T(HttpContext, "Female")</option>
        </select>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Avatar")
        <span class="file-picker">
            <input asp-for="Input.Avatar" type="file" accept="image/*" data-avatar-crop-input />
            <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "ChooseFile")</span>
        </span>
    </label>

    <label class="check-line profile-toggle">
        <input asp-for="Input.AutoTranslateMessages" type="checkbox" />
        <span>@TechSupportRagBot.Services.UiText.T(HttpContext, "AutoTranslate")</span>
    </label>

    @if (User.IsInRole("Operator") || User.IsInRole("Admin"))
    {
        <div class="inline-grid">
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "WorkdayStart")
                <input asp-for="Input.WorkdayStart" type="time" />
            </label>
            <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "WorkdayEnd")
                <input asp-for="Input.WorkdayEnd" type="time" />
            </label>
        </div>
    }

    <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "Save")</button>
    <div asp-validation-summary="All" class="text-danger"></div>
</form>

<form method="post" asp-page-handler="ChangePassword" class="panel narrow password-change-panel">
    <div>
        <p class="eyebrow">@TechSupportRagBot.Services.UiText.T(HttpContext, "Account")</p>
        <h2>@TechSupportRagBot.Services.UiText.T(HttpContext, "ChangePassword")</h2>
    </div>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "CurrentPassword")
        <span class="password-field"><input asp-for="PasswordInput.CurrentPassword" type="password" autocomplete="current-password" /><button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">👁</button></span>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "NewPassword")
        <span class="password-field"><input asp-for="PasswordInput.NewPassword" type="password" autocomplete="new-password" /><button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">👁</button></span>
    </label>
    <label>@TechSupportRagBot.Services.UiText.T(HttpContext, "Repeat password")
        <span class="password-field"><input asp-for="PasswordInput.ConfirmPassword" type="password" autocomplete="new-password" /><button class="password-toggle" type="button" data-password-toggle aria-label="Show password" aria-pressed="false">👁</button></span>
    </label>
    <button class="btn-main" type="submit">@TechSupportRagBot.Services.UiText.T(HttpContext, "SavePassword")</button>
    <div asp-validation-summary="All" class="text-danger"></div>
</form>

<div class="avatar-crop-modal" id="avatarCropModal" hidden>
    <div class="avatar-crop-card" role="dialog" aria-modal="true" aria-labelledby="avatarCropTitle">
        <div class="avatar-crop-head">
            <div>
                <h2 id="avatarCropTitle">@TechSupportRagBot.Services.UiText.T(HttpContext, "AvatarCropTitle")</h2>
                <p>@TechSupportRagBot.Services.UiText.T(HttpContext, "AvatarCropHint")</p>
            </div>
            <button class="avatar-crop-close" type="button" aria-label="@TechSupportRagBot.Services.UiText.T(HttpContext, "Cancel")">×</button>
        </div>

        <div class="avatar-crop-stage" id="avatarCropStage">
            <img id="avatarCropImage" alt="" draggable="false" />
            <div class="avatar-crop-mask"></div>
            <div class="avatar-crop-frame"></div>
        </div>

        <label class="avatar-crop-zoom">@TechSupportRagBot.Services.UiText.T(HttpContext, "AvatarZoom")
            <input id="avatarCropZoom" type="range" min="1" max="4" step="0.01" value="1" />
        </label>

        <div class="avatar-crop-actions">
            <button class="btn-secondary" type="button" id="avatarCropCancel">@TechSupportRagBot.Services.UiText.T(HttpContext, "Cancel")</button>
            <button class="btn-main" type="button" id="avatarCropApply">@TechSupportRagBot.Services.UiText.T(HttpContext, "AvatarApply")</button>
        </div>
    </div>
</div>
